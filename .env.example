# Copy to `.env` in the project root (never commit `.env`).
#
# Database setup SQL lives in: for_developers/sql/ (run numbered scripts in order).

# --- Server API (used by `server/index.mjs` — keep secret) ---
# Get Project URL + service_role key from Supabase → Project Settings → API.
# The service role key MUST stay on the server only (bypasses RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: secret for HMAC-signing admin session tokens (Bearer). If unset, a stable key is derived from the
# service role key. Set a long random string in production if you prefer rotation independent of Supabase.
# ADMIN_SESSION_SECRET=

# Site owner — your MetaMask / EVM address (0x…). Always treated as admin.
# Register once with this wallet to create the profile; is_admin is applied automatically.
OWNER_WALLET=0xYourOwnerAddressHere

# API-only mode (`npm run dev:server` or split dev): Express listens here. Default 8787.
# On Railway/Render/Fly, the platform sets PORT — that overrides SERVER_PORT.
SERVER_PORT=8787
# API-only bind address. Default 0.0.0.0 (required for cloud). Use 127.0.0.1 for localhost-only.
# LISTEN_HOST=0.0.0.0

# Public API origin (no trailing slash) — used in JSON image URLs behind a reverse proxy.
# PUBLIC_API_ORIGIN=https://api.bop-rh.xyz
# Optional override for NFT PNG folder (default: public/images/nfts)
# NFT_IMAGES_DIR=/opt/bop/public/images/nfts

# Combined dev (`npm run dev`): Vite + API share one port. Default 2000.
# PORT=2000

# Required on Netlify: Railway API origin (no trailing slash). `npm run build` runs scripts/netlify-prebuild.mjs
# which writes public/_redirects to proxy /api/* → Railway (browser uses same-origin /api; no CORS).
# Netlify: Environment variables → VITE_API_BASE → redeploy (Clear cache and deploy).
# VITE_API_BASE=https://your-api-host.example.com

# --- EVM / Robinhood Chain ---
# $BOP ERC-20 contract address (0x…). NOT a balance number.
# Optional: if unset, the server reads `bopTokenAddress` from `project.public.json`.
# Legacy env name still accepted: LITE_TOKEN_MINT
BOP_TOKEN_ADDRESS=
# BOP Reward NFT (400k $BOP ↔ 1 NFT). Owner calls setBopToken after token exists.
BOP_REWARD_NFT_ADDRESS=
# Optional: IPFS metadata folder for deploy (must end with /). tokenURI(n) = this + n + ".json"
# NFT_METADATA_BASE_URI=ipfs://bafybeih7chpwmivkqv4dhy7unlxzkhp43klpu474j742hh3i76qwliy3i4/

# Robinhood Chain JSON-RPC for $BOP balanceOf reads and forum attestations.
# Legacy names still accepted: ETH_RPC_URL, RPC_URL
ROBINHOOD_RPC_URL=

# Forum on-chain attestations (BopForumAttestation). Relayer pays gas; users only sign messages.
# Deploy: cd contracts && npx hardhat run scripts/deploy-forum-attestation.js --network robinhood
BOP_FORUM_ATTESTATION_ADDRESS=
# Hex private key for the relayer EOA (must match contract.relayer). Keep server-only.
ATTESTATION_RELAYER_PRIVATE_KEY=

# Supabase Storage: run for_developers/sql/003_storage_avatars.sql so profile photo uploads work.

# --- Optional: Vite client ---
# Only if the frontend calls Supabase directly later (public data). Not required for registration.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Explorer link bases (no trailing slash). Defaults: https://rh-scan.xyz/tx and .../address
# VITE_CHAIN_EXPLORER_TX_BASE=https://rh-scan.xyz/tx
# VITE_CHAIN_EXPLORER_ADDRESS_BASE=https://rh-scan.xyz/address

# --- Legacy Solana (optional; leftover memo / SPL dividend paths — not required for forum login) ---
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_MEMO_RPC_URL=
# SOLANA_MEMO_FEE_PAYER_SECRET_KEY=
# TREASURY_WALLET_SECRET_KEY=
# SPL_DIVIDEND_SENDER=
